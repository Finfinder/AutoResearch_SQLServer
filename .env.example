# .env.example — copy this file to .env and fill in your values
# The .env file is listed in .gitignore and must never be committed to the repository.

# ─── SQL Server Connection ────────────────────────────────────────────────────

# ODBC driver name. Change to "ODBC Driver 18 for SQL Server" if using Driver 18.
DB_DRIVER=ODBC Driver 17 for SQL Server

# Hostname or IP address of the SQL Server instance (e.g. localhost, 192.168.1.10, server\instance)
DB_SERVER=localhost

# Name of the target database
DB_DATABASE=your_database_name

# SQL Server login (SQL Authentication)
DB_UID=your_username

# SQL Server password (SQL Authentication)
DB_PWD=your_password

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level for console (stderr) output. Supported values: DEBUG, INFO, WARNING, ERROR.
# File log (logs/autoresearch_YYYYMMDD_HHMMSS.log) always captures all levels (DEBUG and above).
# Each run creates a new timestamped log file in the logs/ directory.
LOG_LEVEL=INFO
